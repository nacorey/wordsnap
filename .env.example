# ===========================================
# WordSnap 환경 변수 가이드
# 이 파일을 복사하여 .env.local 로 저장한 뒤 값을 채워 넣으세요.
# .env.local 은 git에 포함되지 않습니다.
# ===========================================

# --- Google AI Studio (이미지 분석·콜로케이션 생성) ---
# https://aistudio.google.com/apikey 에서 발급
# /api/analyze, /api/words 엔드포인트에서 사용
GOOGLE_AI_API_KEY=AIza...

# --- Supabase (Auth 등) ---
# https://supabase.com/dashboard 프로젝트 > Settings > API 에서 확인
# Google 로그인: Authentication > Providers > Google 활성화 후
#   Google Cloud Console에서 OAuth 클라이언트 ID/비밀번호 발급해 입력
# Redirect URL: Authentication > URL Configuration에
#   http://localhost:3000/auth/callback (개발)
#   https://wordsnap-daddy.vercel.app/auth/callback (배포) 추가
NEXT_PUBLIC_SUPABASE_URL=https://htyqazbofuyeskykublh.supabase.co
# anon public key: API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
